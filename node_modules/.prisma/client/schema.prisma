// AgroConecta - Esquema de base de datos
// Plataforma para que pequenos agricultores gestionen fincas, cultivos y cosechas

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Farmer {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farms Farm[]

  @@map("farmers")
}

model Farm {
  id        Int      @id @default(autoincrement())
  name      String
  location  String
  sizeHa    Float    @map("size_ha")
  farmerId  Int      @map("farmer_id")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farmer Farmer @relation(fields: [farmerId], references: [id], onDelete: Cascade)
  crops  Crop[]

  @@map("farms")
}

enum CropStatus {
  PLANTED
  GROWING
  READY_TO_HARVEST
  HARVESTED
}

model Crop {
  id                  Int        @id @default(autoincrement())
  name                String
  farmId              Int        @map("farm_id")
  plantedDate         DateTime   @map("planted_date")
  expectedHarvestDate DateTime   @map("expected_harvest_date")
  status              CropStatus @default(PLANTED)
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  farm     Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  harvests HarvestRecord[]

  @@map("crops")
}

model HarvestRecord {
  id           Int      @id @default(autoincrement())
  cropId       Int      @map("crop_id")
  harvestDate  DateTime @map("harvest_date")
  quantityKg   Float    @map("quantity_kg")
  qualityGrade String   @map("quality_grade")
  notes        String?
  createdAt    DateTime @default(now())

  crop Crop @relation(fields: [cropId], references: [id], onDelete: Cascade)

  @@map("harvest_records")
}
