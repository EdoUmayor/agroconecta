# Puerto en el que corre la API
PORT=3000
NODE_ENV=development

# Conexion a PostgreSQL (usada por Prisma)
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/BASE_DE_DATOS?schema=public
DATABASE_URL="postgresql://postgres:123@localhost:5432/agroconecta_db?schema=public"

# Variables usadas por docker-compose para levantar el contenedor de PostgreSQL
POSTGRES_USER=agroconecta_user
POSTGRES_PASSWORD=agroconecta_pass
POSTGRES_DB=agroconecta_db

# JWT
JWT_SECRET=super_secreto_cambiar_en_produccion_2024
JWT_EXPIRES_IN=1d
